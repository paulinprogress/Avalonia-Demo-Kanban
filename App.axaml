<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia_Demo_Kanban.App"
             xmlns:local="using:Avalonia_Demo_Kanban"
             RequestedThemeVariant="Default"> <!-- Follows system theme ("Dark" or "Light") -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key='Light'>
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="ColumnBackgroundBrush" Color="#F1F1F1"/>
                    <SolidColorBrush x:Key="TaskBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AddButtonBackgroundBrush" Color="#E8E8E8"/>
                    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#0E0E0E"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key='Dark'>
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1A1A1A"/> <!-- 121212 -->
                    <SolidColorBrush x:Key="ColumnBackgroundBrush" Color="#2A2A2A"/>
                    <SolidColorBrush x:Key="TaskBackgroundBrush" Color="#3A3A3A"/>
                    <SolidColorBrush x:Key="AddButtonBackgroundBrush" Color="#3A3A3A"/>
                    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#EFEFEF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Button.add-button">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Border:pointerover Button.add-button">
            <Setter Property="Opacity" Value="1"/>
        </Style>

    </Application.Styles>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
    
</Application>