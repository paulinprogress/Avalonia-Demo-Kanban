<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Avalonia_Demo_Kanban.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Avalonia_Demo_Kanban.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Kanban Board"
        Width="900"
        Height="600"
        Background="{DynamicResource WindowBackgroundBrush}"
        DragDrop.DragOver="Task_DragOver"
        DragDrop.Drop="Task_Drop"
        DragDrop.AllowDrop="True">

    <Grid>
        <ItemsControl ItemsSource="{Binding Columns}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="3"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate>

                <!-- Column template -->
                <Border Name="ColumnRoot"
                    Background="{DynamicResource ColumnBackgroundBrush}"
                    CornerRadius="12"
                    Padding="12"
                    Margin="8"
                    DragDrop.Drop="Task_Drop"
                    DragDrop.AllowDrop="True">

                    <Grid RowDefinitions="Auto,*,Auto">

                        <TextBlock Text="{Binding Title}"
                            FontSize="18"
                            FontWeight="Bold"
                            Margin="0,0,0,12"
                            Foreground="{DynamicResource ControlForegroundBrush}"/>

                        <ItemsControl Grid.Row="1"
                                    ItemsSource="{Binding Tasks}"
                                    ClipToBounds="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    
                                    <!-- Task template -->
                                    <Border Background="{DynamicResource TaskBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="8"
                                        Margin="0,0,0,8"
                                        PointerPressed="Task_PointerPressed">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Title}"
                                                    TextWrapping="Wrap"
                                                    Foreground="{DynamicResource ControlForegroundBrush}"/>

                                            <!-- Looks for *second* Border element in parents to bind RemoveTaskCommand -->
                                            <Button Grid.Column="1"
                                                    Content="×"
                                                    Margin="8,0,0,0"
                                                    CornerRadius="8"
                                                    Background="Transparent"
                                                    Command="{Binding $parent[Border;1].((vm:KanbanColumnViewModel)DataContext).RemoveTaskCommand}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>

                                        <Border.Styles>
                                            <!-- Base Style -->
                                            <Style Selector="Border">
                                                <Setter Property="RenderTransform" Value="scale(1)" />
                                                <Setter Property="ZIndex" Value="0" />
                                                <Setter Property="Transitions">
                                                    <Transitions>
                                                        <!-- Smoothly animate the scale over 0.2 seconds -->
                                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Setter>
                                            </Style>

                                            <!-- Hover Style -->
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="RenderTransform" Value="scale(1.05)" />
                                                <Setter Property="ZIndex" Value="10" />
                                            </Style>
                                        </Border.Styles>

                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Plus button (visible if column has add button, when not currently adding) -->
                        <Button Grid.Row="2"
                                Content="+"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,8,0,0"
                                CornerRadius="8"
                                Background="{DynamicResource AddButtonBackgroundBrush}"
                                Command="{Binding ShowTaskInputCommand}">
                            <Button.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="HasAddTaskButton" />
                                    <Binding Path="!IsCreatingTask" />
                                </MultiBinding>
                            </Button.IsVisible>
                        </Button>

                        <!-- TextBox and Add button container (visible if column has add button, when adding) -->
                        <Grid Grid.Row="2"
                              ColumnDefinitions="*,Auto"
                              Margin="0,8,0,0">
                            <Grid.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="HasAddTaskButton" />
                                    <Binding Path="IsCreatingTask" />
                                </MultiBinding>
                            </Grid.IsVisible>

                            <TextBox Grid.Column="0"
                                    CornerRadius="8"
                                    Background="{DynamicResource AddButtonBackgroundBrush}"
                                    Watermark="New task..."
                                    Text="{Binding NewTaskText, Mode=TwoWay}"
                                    KeyDown="TextBox_KeyDown"/>
                            <Button Grid.Column="1"
                                    Content="✓"
                                    Margin="8,0,0,0"
                                    CornerRadius="8"
                                    Background="{DynamicResource AddButtonBackgroundBrush}"
                                    Command="{Binding CreateTaskCommand}"/>
                        </Grid>


                    </Grid>
                </Border>

            </DataTemplate>
        </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Ghost task item (overlay) -->
        <Border Name="GhostItem"
                CornerRadius="8"
                Background="{DynamicResource TaskBackgroundBrush}"
                IsVisible="False"
                IsHitTestVisible="False"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <TextBlock Text="{Binding DraggingTaskItem.Title}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ControlForegroundBrush}"
                       Margin="8"/>
        </Border>
    </Grid>

</Window>
