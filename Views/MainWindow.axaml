<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Avalonia_Demo_Kanban.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Avalonia_Demo_Kanban.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Kanban Board"
        Width="900"
        Height="600">

    <ItemsControl ItemsSource="{Binding Columns}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="3"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Name="ColumnRoot"
                        Background="#2A2A2A"
                        CornerRadius="12"
                        Padding="12"
                        Margin="8">

                    <Grid RowDefinitions="Auto,*,Auto,Auto">

                        <TextBlock Text="{Binding Title}"
                                FontSize="18"
                                FontWeight="Bold"
                                Margin="0,0,0,12"/>

                        <ItemsControl Grid.Row="1"
                                    ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3A3A3A"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,0,0,8">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Title}"/>

                                            <!-- Looks for *second* Border element in parents (index 1) to bind RemoveTaskCommand -->
                                            <Button Grid.Column="1"
                                                    Content="×"
                                                    Margin="8,0,0,0"
                                                    Background="Transparent"
                                                    Command="{Binding $parent[Border;1].((vm:KanbanColumnViewModel)DataContext).RemoveTaskCommand}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBox Grid.Row="2"
                                Classes="add-textbox"
                                Watermark="New task..."
                                Text="{Binding NewTaskText, Mode=TwoWay}"
                                Margin="0,8,0,0"/>

                        <Button Grid.Row="3"
                                Classes="add-button"
                                Content="+"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,8,0,0"
                                Command="{Binding AddTaskCommand}"/>


                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>

</Window>
