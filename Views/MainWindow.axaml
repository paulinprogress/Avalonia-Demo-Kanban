<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Avalonia_Demo_Kanban.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Avalonia_Demo_Kanban.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Kanban Board"
        Width="900"
        Height="600">

    <Grid ColumnDefinitions="*,*,*" Margin="16">

        <!-- TODO COLUMN -->
        <Border Grid.Column="0"
                Background="#eaecf1"
                CornerRadius="12"
                Padding="12"
                Margin="8">

            <StackPanel>
                <TextBlock Text="TODO"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <Border Background="#cdcfda"
                        CornerRadius="8"
                        Padding="8"
                        Margin="0,0,0,8">
                    <TextBlock Text="Example Task A"/>
                </Border>

                <Border Background="#cdcfda"
                        CornerRadius="8"
                        Padding="8">
                    <TextBlock Text="Example Task B"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- DOING COLUMN -->
        <Border Grid.Column="1"
                Background="#eaecf1"
                CornerRadius="12"
                Padding="12"
                Margin="8">

            <StackPanel>
                <TextBlock Text="DOING"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <Border Background="#cdcfda"
                        CornerRadius="8"
                        Padding="8">
                    <TextBlock Text="Working on feature"/>
                </Border>
            </StackPanel>

        </Border>

        <!-- DONE COLUMN -->
        <Border Grid.Column="2"
                Background="#eaecf1"
                CornerRadius="12"
                Padding="12"
                Margin="8">

            <StackPanel>
                <TextBlock Text="DONE"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <Border Background="#cdcfda"
                        CornerRadius="8"
                        Padding="8">
                    <TextBlock Text="Initial setup"/>
                </Border>
            </StackPanel>

        </Border>

    </Grid>
</Window>
